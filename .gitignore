# Ghost OSINT — .gitignore

# Output files generated by the tool
ghost_*.json
ghost_*.txt
ghost_*.html
ghost_log.txt

# Python
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Sensitive — never commit your real token
# config.json with real github_token should stay local
# The blank template config.json IS committed
